# Disable browser caching for admin JavaScript modules.
#
# Rationale: admin/index.php appends ?v=<filemtime> to the entry script
# (app.js), but native ES module imports (import { x } from './schema.js')
# do NOT inherit the parent's query string. Each module is therefore cached
# by the browser under its bare URL and can go stale across deployments,
# leading to hard-to-diagnose mismatches between updated backend endpoints
# and cached frontend code.
#
# The admin panel is used only by administrators, so disabling cache for a
# few small JS files has a negligible bandwidth impact while guaranteeing
# that every deploy is picked up immediately.

<IfModule mod_headers.c>
    <FilesMatch "\.(js|mjs)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Defense-in-depth: deny direct web access to any JSON files in this directory.
# Admin endpoints are PHP; no .json should ever be served from here. Covers both
# Apache 2.4+ (mod_authz_core) and 2.2 (mod_access_compat / mod_authz_host).
<FilesMatch "\.json$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
