{
    "_instructions": "PostgreSQL connection configuration. Rename this file to 'database.json' and update the values below with your database credentials. Alternatively, configure these values via the admin panel (System → Database). NOTE: This file is never included in release zips — create it manually or via the UI on first deployment.",
    "_comment_host": "PostgreSQL server hostname (e.g., localhost, db.example.com, or an AWS RDS endpoint)",
    "host": "localhost",
    "_comment_port": "PostgreSQL server port (default: 5432)",
    "port": "5432",
    "_comment_dbname": "Database name to use (will be created if it does not exist; typical name: opensparrow)",
    "dbname": "opensparrow",
    "_comment_user": "PostgreSQL username with CREATE DATABASE privileges",
    "user": "postgres",
    "_comment_password": "PostgreSQL password (should be a strong, randomly generated value — use: openssl rand -base64 32)",
    "password": "your_strong_password_here",
    "_comment_schema": "PostgreSQL schema name where system tables are created (default: app). Rarely changed.",
    "schema": "app"
}
